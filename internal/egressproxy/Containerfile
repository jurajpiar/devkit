FROM golang:1.23-alpine AS builder

WORKDIR /app

# Copy go mod files first for better caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build the egress proxy binary
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /egressproxy ./cmd/egressproxy

# Final minimal image
FROM alpine:3.20

RUN apk add --no-cache ca-certificates

COPY --from=builder /egressproxy /usr/local/bin/egressproxy

# Default port
EXPOSE 3128

ENTRYPOINT ["/usr/local/bin/egressproxy"]
CMD ["-listen", ":3128"]
